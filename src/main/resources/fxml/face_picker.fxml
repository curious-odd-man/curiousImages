<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
    ═══════════════════════════════════════════════════════
    FACE PICKER (modal)
    Grid of every tagged face for a person. Clicking a face makes it the
    cover face immediately — see PersonDetailController#onBrowseFaces and
    FacePickerController.
    ═══════════════════════════════════════════════════════
-->

<BorderPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="1080.0" prefWidth="1920.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.github.curiousoddman.curious_images.ui.controller.screen.FacePickerController">

    <top>
        <Label fx:id="titleLabel" styleClass="dialog-title" text="Click a face to set as cover · Ctrl/Shift-click to select multiple · Right-click for actions">
            <BorderPane.margin>
                <Insets bottom="8.0" left="12.0" right="12.0" top="12.0" />
            </BorderPane.margin>
        </Label>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="transparent-background" BorderPane.alignment="CENTER">
            <VBox fx:id="faceSectionsBox" spacing="12.0">
                <padding><Insets bottom="12.0" left="12.0" right="12.0" top="4.0" /></padding>
            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="8.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="12.0" left="12.0" right="12.0" top="8.0" />
            </padding>
            <Label fx:id="selectionCountLabel" styleClass="muted-text" HBox.hgrow="ALWAYS" />
            <Button fx:id="moveSelectedMenuButton" mnemonicParsing="false" onAction="#onMoveSelected" text="Move Selected to…" />
            <Button fx:id="cancelButton" cancelButton="true" onAction="#onCancel" text="Cancel" />
        </HBox>
    </bottom>

</BorderPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>


<?import javafx.geometry.Insets?>
<BorderPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
            xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.github.curiousoddman.curious_images.ui.controller.custom.GridController">
    <center>
        <ListView fx:id="listView" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308">

        </ListView>
    </center>
    <top>
        <HBox alignment="CENTER_LEFT" spacing="8.0">
            <padding>
                <Insets bottom="4.0" left="10.0" right="10.0" top="4.0"/>
            </padding>
            <Label text="Thumbnail size:"/>
            <Slider fx:id="thumbnailSizeSlider" blockIncrement="16.0" max="320.0" min="64.0" prefWidth="180.0"
                    value="128.0"/>
            <Label fx:id="photoCountLabel" text=""/>
        </HBox>
    </top>
</BorderPane>

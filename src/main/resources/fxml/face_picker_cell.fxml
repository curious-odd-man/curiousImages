<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>

<!--
    One cell in face_picker.fxml's grid: a single face thumbnail. Clicking it selects that face
    as the new cover (see FacePickerCellController). The star badge is shown for whichever face
    is currently the person's cover, so it's easy to spot in a grid of many faces.
-->
<StackPane fx:id="cellRoot" xmlns="http://javafx.com/javafx/17.0.12"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.github.curiousoddman.curious_images.ui.controller.screen.FacePickerCellController"
           minWidth="100.0" minHeight="100.0" maxWidth="100.0" maxHeight="100.0"
           styleClass="face-cell">

    <ImageView fx:id="thumbImageView" fitWidth="96.0" fitHeight="96.0" preserveRatio="true"/>

    <ProgressIndicator fx:id="loadIndicator" visible="false" maxWidth="32.0" maxHeight="32.0"/>

    <Label fx:id="coverBadge" text="★ Cover" visible="false" styleClass="face-cover-badge"
           StackPane.alignment="TOP_RIGHT"/>
</StackPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="0.0" minWidth="0.0"
            prefHeight="1080.0" prefWidth="1920.0" xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.github.curiousoddman.curious_images.ui.controller.screen.LibraryController">
    <center>
        <BorderPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="0.0" minWidth="0.0">
            <center>
                <SplitPane fx:id="librarySplitPane" dividerPositions="0.2559" maxHeight="1.7976931348623157E308"
                           maxWidth="1.7976931348623157E308" minHeight="0.0" minWidth="0.0"
                           BorderPane.alignment="CENTER">
                    <items>
                        <AnchorPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="0.0"
                                    minWidth="0.0">
                            <children>
                                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" maxHeight="1.7976931348623157E308"
                                            maxWidth="1.7976931348623157E308" AnchorPane.bottomAnchor="0.0"
                                            AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
                                            AnchorPane.topAnchor="0.0">
                                    <content>
                                        <VBox fx:id="artistList" alignment="CENTER" maxHeight="1.7976931348623157E308"
                                              maxWidth="1.7976931348623157E308"/>
                                    </content>
                                </ScrollPane>
                            </children>
                        </AnchorPane>
                        <AnchorPane fx:id="playlistAnchorPane" maxHeight="1.7976931348623157E308"
                                    maxWidth="1.7976931348623157E308" minHeight="0.0" minWidth="0.0"/>
                    </items>
                </SplitPane>
            </center>
        </BorderPane>
    </center>
    <top>
        <MenuBar BorderPane.alignment="CENTER">
            <menus>
                <Menu mnemonicParsing="false" text="File">
                    <items>
                        <MenuItem mnemonicParsing="false" onAction="#onRescanMenuClicked" text="Rescan library..."/>
                        <MenuItem mnemonicParsing="false" text="Close"/>
                    </items>
                </Menu>
                <Menu mnemonicParsing="false" text="Edit">
                    <items>
                        <MenuItem mnemonicParsing="false" text="Delete"/>
                    </items>
                </Menu>
                <Menu mnemonicParsing="false" text="Help">
                    <items>
                        <MenuItem mnemonicParsing="false" text="About"/>
                    </items>
                </Menu>
            </menus>
        </MenuBar>
    </top>
    <bottom>
        <!-- Minimal import progress/cancel status bar (implementation plan §11). Intentionally
             separate from the leftover music-player nodes above, which are unrelated and will be
             removed wholesale when the real Grid/Library UI is built in a later phase. -->
        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="import-status-bar" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="6.0" left="10.0" right="10.0" top="6.0"/>
            </padding>
            <children>
                <Label fx:id="importProgressLabel" text=""/>
                <Label fx:id="importCurrentFileLabel" text="" HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"/>
                <Label fx:id="importElapsedLabel" text=""/>
                <Button fx:id="importCancelButton" mnemonicParsing="false" onAction="#onCancelImport" text="Cancel"
                        visible="false" managed="false"/>
            </children>
        </HBox>
    </bottom>
</BorderPane>


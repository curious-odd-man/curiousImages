<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="0.0" minWidth="0.0" prefHeight="1080.0" prefWidth="1920.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.github.curiousoddman.curious_images.ui.controller.screen.LibraryController">
    <center>
        <SplitPane fx:id="librarySplitPane" dividerPositions="0.2559" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="0.0" minWidth="0.0" BorderPane.alignment="CENTER">
            <items>
                                <!-- Left: library tree -->
                                <AnchorPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="0.0" minWidth="0.0">
                                    <children>
                                        <!--
                                            DnD: files and folders dropped anywhere on the tree view
                                            are handled by LibraryController#onTreeDragOver /
                                            onTreeDragDropped. When dropped onto an IMPORT_ROOT or
                                            FOLDER node the root path is pre-filled in the dialog;
                                            a drop on any other node defaults to no pre-fill.
                                        -->
                                        <TreeView fx:id="libraryTreeView" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" onDragDropped="#onTreeDragDropped" onDragOver="#onTreeDragOver" showRoot="false" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" />
                                    </children>
                                </AnchorPane>

                                <!--
                                    Right: StackPane with two layers.
                                    Only one is visible at a time — toggled by LibraryController.

                                    Layer 0 (photoGridView)   — shown for folders, timeline, albums, search.
                                    Layer 1 (personDetailContainer) — shown when a PERSON node is selected;
                                             content is loaded from person_detail.fxml and injected at runtime.
                                -->
                                <AnchorPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="0.0" minWidth="0.0">
                                    <children>
                                        <StackPane fx:id="contentStack" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

                                            <!-- ── Photo grid (default view) ── -->
                                            <BorderPane fx:id="photoGridView" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308">
                                                <top>
                                                    <VBox spacing="0.0" BorderPane.alignment="CENTER">
                                                        <!-- Search bar row -->
                                                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                                                            <padding>
                                                                <Insets bottom="4.0" left="10.0" right="10.0" top="6.0" />
                                                            </padding>
                                                            <TextField fx:id="searchField" promptText="Search photos... (semantic / AI)" HBox.hgrow="ALWAYS" />
                                                            <Button fx:id="searchButton" mnemonicParsing="false" onAction="#onSearchClicked" text="Search" />
                                                            <Button fx:id="clearSearchButton" mnemonicParsing="false" onAction="#onClearSearchClicked" text="✕" visible="false" />
                                                        </HBox>
                                                        <!-- Thumbnail-size row -->
                                                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                                                            <padding>
                                                                <Insets bottom="6.0" left="10.0" right="10.0" top="4.0" />
                                                            </padding>
                                                            <Label text="Thumbnail size:" />
                                                            <Slider fx:id="thumbnailSizeSlider" blockIncrement="16.0" max="320.0" min="64.0" prefWidth="200.0" value="128.0" />
                                                            <Label fx:id="photoCountLabel" text="" />
                                                        </HBox>
                                                    </VBox>
                                                </top>
                                                <center>
                                                    <!-- Virtualized photo grid: each ListView cell is one row of
                                                         photo_cell.fxml instances (see PhotoRowCell /
                                                         PhotoGridRowController). ListView's own virtual flow only
                                                         ever instantiates enough rows to cover the viewport plus a
                                                         small buffer, and recycles them on scroll, so the number of
                                                         live nodes stays bounded no matter how many thousands of
                                                         photos are in the selection. -->
                                                    <ListView fx:id="photoGridListView" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" BorderPane.alignment="CENTER">
                                                        <padding>
                                                            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                                                        </padding>
                                                    </ListView>
                                                </center>
                                            </BorderPane>

                                            <!-- ── Person detail panel (injected at runtime) ── -->
                                            <AnchorPane fx:id="personDetailContainer" managed="false" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" visible="false" />

                                            <!-- ── Duplicates review panel (injected from duplicates.fxml at
                                                 runtime in LibraryController#initialize) ── -->
                                            <AnchorPane fx:id="duplicatesContainer" managed="false" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" visible="false" />
                     <AnchorPane fx:id="folderDuplicatesContainer" layoutX="10.0" layoutY="10.0" managed="false" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" visible="false" />

                                        </StackPane>
                                    </children>
                                </AnchorPane>
                            </items>
                        </SplitPane>
    </center>
    <top>
        <MenuBar BorderPane.alignment="CENTER">
            <menus>
                <Menu mnemonicParsing="false" text="File">
                    <items>
                        <!-- Existing: single-root rescan via path-entry modal -->
                        <MenuItem mnemonicParsing="false" onAction="#onRescanMenuClicked" text="Rescan library..." />

                        <!-- NEW: multi-root rescan via checkbox picker -->
                        <MenuItem mnemonicParsing="false" onAction="#onRescanRootsMenuClicked" text="Rescan existing roots..." />

                        <!-- NEW: add new files / folders via copy or new-root -->
                        <MenuItem mnemonicParsing="false" onAction="#onAddFilesMenuClicked" text="Add files / folders..." />

                        <SeparatorMenuItem />
                        <MenuItem mnemonicParsing="false" onAction="#onFindDuplicates" text="Find duplicates" />
                        <MenuItem mnemonicParsing="false" onAction="#onTriggerAiPipeline" text="Trigger AI pipeline" />
                        <SeparatorMenuItem />
                        <MenuItem mnemonicParsing="false" text="Close" />
                    </items>
                </Menu>
                <Menu mnemonicParsing="false" text="Edit">
                    <items>
                        <MenuItem mnemonicParsing="false" text="Delete" />
                    </items>
                </Menu>
                <Menu mnemonicParsing="false" text="Help">
                    <items>
                        <MenuItem mnemonicParsing="false" text="About" />
                    </items>
                </Menu>
            </menus>
        </MenuBar>
    </top>
    <bottom>
        <HBox fx:id="backgroundProgressContainer" alignment="CENTER_LEFT" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" spacing="12.0" visible="false" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="6.0" left="10.0" right="10.0" top="6.0" />
            </padding>
            <Label fx:id="backgroundProcessTitleLabel" maxWidth="1.7976931348623157E308" text="Running: xxxxx" />
            <Button fx:id="backgroundProcessCancelButton" cancelButton="true" mnemonicParsing="false" onAction="#onCancelBackgroundJob" text="❌" textFill="RED">
                <font>
                    <Font size="14.0" />
                </font>
            </Button>
            <StackPane fx:id="backgroundProgressBarContainer">
                <children>
                    <ProgressBar fx:id="backgroundProgressBar" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefWidth="400.0" />
                    <Label fx:id="backgroundProgressLabel" contentDisplay="CENTER" styleClass="progress-label-shadow" text="1 of 10" textAlignment="CENTER" textFill="WHITE">
                        <font>
                            <Font name="System Bold" size="20.0" />
                        </font>
                    </Label>
                </children>
            </StackPane>
            <Label fx:id="backgroundProgressDescription" maxWidth="1.7976931348623157E308" text="here goes file name" HBox.hgrow="ALWAYS" />
        </HBox>
    </bottom>
</BorderPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TreeView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
            minHeight="0.0" minWidth="0.0" prefHeight="1080.0" prefWidth="1920.0"
            xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.github.curiousoddman.curious_images.ui.controller.screen.LibraryController">
    <center>
        <TabPane fx:id="mainTabPane" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                 tabClosingPolicy="UNAVAILABLE" BorderPane.alignment="CENTER">
            <tabs>
                <Tab text="Library">
                    <content>
                        <SplitPane fx:id="librarySplitPane" dividerPositions="0.2559"
                                   maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                                   minHeight="0.0" minWidth="0.0">
                            <items>
                                <!-- Left: library tree -->
                                <AnchorPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                                            minHeight="0.0" minWidth="0.0">
                                    <children>
                                        <TreeView fx:id="libraryTreeView"
                                                  maxHeight="1.7976931348623157E308"
                                                  maxWidth="1.7976931348623157E308"
                                                  showRoot="false"
                                                  AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                                                  AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0"/>
                                    </children>
                                </AnchorPane>

                                <!--
                                    Right: StackPane with two layers.
                                    Only one is visible at a time — toggled by LibraryController.

                                    Layer 0 (photoGridView)   — shown for folders, timeline, albums, search.
                                    Layer 1 (personDetailContainer) — shown when a PERSON node is selected;
                                             content is loaded from person_detail.fxml and injected at runtime.
                                -->
                                <AnchorPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                                            minHeight="0.0" minWidth="0.0">
                                    <children>
                                        <StackPane fx:id="contentStack"
                                                   AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                                                   AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

                                            <!-- ── Photo grid (default view) ── -->
                                            <BorderPane fx:id="photoGridView"
                                                        maxHeight="1.7976931348623157E308"
                                                        maxWidth="1.7976931348623157E308">
                                                <top>
                                                    <VBox spacing="0.0" BorderPane.alignment="CENTER">
                                                        <!-- Search bar row -->
                                                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                                                            <padding>
                                                                <Insets bottom="4.0" left="10.0" right="10.0" top="6.0"/>
                                                            </padding>
                                                            <TextField fx:id="searchField"
                                                                       promptText="Search photos... (semantic / AI)"
                                                                       HBox.hgrow="ALWAYS"/>
                                                            <Button fx:id="searchButton" mnemonicParsing="false"
                                                                    onAction="#onSearchClicked" text="Search"/>
                                                            <Button fx:id="clearSearchButton" mnemonicParsing="false"
                                                                    onAction="#onClearSearchClicked" text="✕"
                                                                    visible="false"/>
                                                        </HBox>
                                                        <!-- Thumbnail-size row -->
                                                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                                                            <padding>
                                                                <Insets bottom="6.0" left="10.0" right="10.0" top="4.0"/>
                                                            </padding>
                                                            <Label text="Thumbnail size:"/>
                                                            <Slider fx:id="thumbnailSizeSlider" blockIncrement="16.0"
                                                                    max="320.0" min="64.0" prefWidth="200.0"
                                                                    value="128.0"/>
                                                            <Label fx:id="photoCountLabel" text=""/>
                                                        </HBox>
                                                    </VBox>
                                                </top>
                                                <center>
                                                    <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                                                                maxHeight="1.7976931348623157E308"
                                                                maxWidth="1.7976931348623157E308"
                                                                BorderPane.alignment="CENTER">
                                                        <content>
                                                            <FlowPane fx:id="photoGridPane" hgap="8.0"
                                                                      maxWidth="1.7976931348623157E308" vgap="8.0">
                                                                <padding>
                                                                    <Insets bottom="10.0" left="10.0"
                                                                            right="10.0" top="10.0"/>
                                                                </padding>
                                                            </FlowPane>
                                                        </content>
                                                    </ScrollPane>
                                                </center>
                                            </BorderPane>

                                            <!-- ── Person detail panel (injected at runtime) ── -->
                                            <AnchorPane fx:id="personDetailContainer"
                                                        maxHeight="1.7976931348623157E308"
                                                        maxWidth="1.7976931348623157E308"
                                                        visible="false" managed="false"/>

                                        </StackPane>
                                    </children>
                                </AnchorPane>
                            </items>
                        </SplitPane>
                    </content>
                </Tab>
                <!-- Duplicates review: content loaded from duplicates.fxml in LibraryController#initialize -->
                <Tab fx:id="duplicatesTab" text="Duplicates"/>
            </tabs>
        </TabPane>
    </center>
    <top>
        <MenuBar BorderPane.alignment="CENTER">
            <menus>
                <Menu mnemonicParsing="false" text="File">
                    <items>
                        <MenuItem mnemonicParsing="false" onAction="#onRescanMenuClicked" text="Rescan library..."/>
                        <MenuItem mnemonicParsing="false" onAction="#onFindDuplicates" text="Find duplicates"/>
                        <MenuItem mnemonicParsing="false" onAction="#onTriggerAiPipeline" text="Trigger AI pipeline"/>
                        <MenuItem mnemonicParsing="false" text="Close"/>
                    </items>
                </Menu>
                <Menu mnemonicParsing="false" text="Edit">
                    <items>
                        <MenuItem mnemonicParsing="false" text="Delete"/>
                    </items>
                </Menu>
                <Menu mnemonicParsing="false" text="Help">
                    <items>
                        <MenuItem mnemonicParsing="false" text="About"/>
                    </items>
                </Menu>
            </menus>
        </MenuBar>
    </top>
    <bottom>
        <HBox alignment="CENTER_LEFT" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
              spacing="12.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="6.0" left="10.0" right="10.0" top="6.0"/>
            </padding>
            <Button fx:id="backgroundProcessCancelButton" cancelButton="true"
                    maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                    mnemonicParsing="false" onAction="#onCancelBackgroundJob"
                    text="❌" textFill="RED" visible="false">
                <font><Font size="14.0"/></font>
            </Button>
            <ProgressIndicator fx:id="backgroundProgressIndicator" progress="0.0"/>
            <Label fx:id="backgroundProgressLabel"/>
            <Label fx:id="backgroundProgressText" maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS"/>
        </HBox>
    </bottom>
</BorderPane>

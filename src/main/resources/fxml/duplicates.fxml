<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.github.curiousoddman.curious_images.ui.controller.screen.DuplicatesController">
    <center>
        <ScrollPane fitToWidth="true" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" BorderPane.alignment="CENTER">
         <content>
            <VBox fx:id="dupliacteItemsVbox" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" spacing="15.0" />
         </content>
        </ScrollPane>
    </center>
   <top>
        <HBox alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" spacing="10.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            <children>
                <Button fx:id="keepSelectedButton" disable="true" mnemonicParsing="false" onAction="#onKeepSelectedClicked" text="✔ Keep Marked" />
                <Button fx:id="deleteSelectedButton" disable="true" mnemonicParsing="false" onAction="#onDeleteSelectedClicked" text="❌ Delete Marked" />
            </children>
        </HBox>
   </top>
   <bottom>
          <HBox alignment="CENTER" fillHeight="false" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" spacing="20.0" BorderPane.alignment="CENTER">
              <children>
                  <Button fx:id="previousDuplicateButton" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showPreviousDuplicate" text="◀ Prev Duplicate">
                      <font>
                          <Font name="Consolas" size="20.0" />
                      </font>
                  </Button>
                  <Label fx:id="duplicateCounterLabel" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" text="1 of 3">
                      <font>
                          <Font name="Consolas" size="30.0" />
                      </font>
                  </Label>
                  <Button fx:id="nextDuplicateButton" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showNextDuplicate" text="Next Duplicate ▶">
                      <font>
                          <Font name="Consolas" size="20.0" />
                      </font>
                  </Button>
              </children>
         <padding>
            <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
         </padding>
          </HBox>
   </bottom>
</BorderPane>

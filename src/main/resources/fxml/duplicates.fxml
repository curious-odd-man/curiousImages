<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.github.curiousoddman.curious_images.ui.controller.screen.DuplicatesController">
    <center>
        <ScrollPane fitToWidth="true" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                    BorderPane.alignment="CENTER">
            <content>
                <Accordion fx:id="duplicatesAccordion" />
            </content>
        </ScrollPane>
    </center>
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="10.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            <children>
                <Button fx:id="keepSelectedButton" disable="true" mnemonicParsing="false"
                        onAction="#onKeepSelectedClicked" text="Keep Selected" />
                <Button fx:id="deleteSelectedButton" disable="true" mnemonicParsing="false"
                        onAction="#onDeleteSelectedClicked" text="Delete Selected" />
            </children>
        </HBox>
    </bottom>
</BorderPane>

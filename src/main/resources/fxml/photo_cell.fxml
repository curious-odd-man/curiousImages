<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<BorderPane fx:id="cellRoot" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.github.curiousoddman.curious_images.ui.controller.custom.PhotoCellController">
   <center>
      <StackPane fx:id="imageSlot" onMouseClicked="#onCellClicked">
          <padding>
              <Insets bottom="6.0" left="6.0" right="6.0" top="6.0" />
          </padding>
      
          <children>
              <Rectangle fx:id="placeholderRect" arcHeight="10.0" arcWidth="10.0" fill="#d8d8d8" />
              <Label fx:id="placeholderLabel" text="Loading...">

              </Label>
              <ImageView fx:id="imageView" managed="false" preserveRatio="true" visible="false" />
          </children>
      </StackPane>
   </center>
   <bottom>
      <Label fx:id="filenameLabel" text="Label" BorderPane.alignment="CENTER" />
   </bottom>
</BorderPane>
